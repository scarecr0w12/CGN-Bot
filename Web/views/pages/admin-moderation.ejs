<!DOCTYPE html>
<html lang="en">
<head>
	<title><%= serverData.name %> Moderation - Skynet Admin Console</title>
	<%- include('../partials/head') %>
	<script src="/static/js/form-change-listener.js"></script>
</head>
<body onload="SkynetUtil.SFS();">
	<%- include('../partials/dashboard-header') %>
	<%- include('../partials/dashboard-socket-updates') %>

	<section class="section is-white">
		<div class="container">
			<div class="columns">
				<div id="menu" class="column is-one-quarter">
					<%- include('../partials/admin-menu') %>
				</div>
				<div class="column">
					<h1 class="title">
						Moderation
					</h1>
					<article class="message is-primary">
						<div class="message-body">
							<div class="content">
								All of Skynet's <strong>moderation features</strong> can be toggled below, including member messages and filters. There are also some miscellaneous moderation options in this section.
							</div>
						</div>
					</article>
					<form id="form" onsubmit="SkynetUtil.submitForm(); return false;">
						<div class="box is-paddingless generic-feature">
							<div class="generic-feature-box">
								<div class="generic-feature-box-slider">
									<div class="field">
										<input id="isEnabled" type="checkbox" name="isEnabled" class="switch is-medium is-success is-rounded menu-modifier"<%= configData.moderation.isEnabled ? " checked " : "" %> data-modifies=".moderation-only-menu-item">
										<label for="isEnabled" style="padding-left: 3.75rem;" data-toggle-gfa="moderation-options"></label>
									</div>
								</div>
								<div class="generic-feature-box-description">
									<p>Act as a <strong>super-smart</strong> server moderator</p>
								</div>
							</div>
							<div id="moderation-options" class="generic-feature-addon"<%- configData.moderation.isEnabled ? '' : ' style="display: none;"' %>>
							<div class="moderation-feature">
								<h4 class="subtitle is-4">
									Autokick Members
								</h4>
								<div class="box is-paddingless generic-feature">
									<div class="generic-feature-box">
										<div class="generic-feature-box-slider">
											<div class="field">
												<input id="autokick_members-isEnabled" type="checkbox" name="autokick_members-isEnabled" class="switch is-medium is-success is-rounded"<%= configData.moderation.autokick_members.isEnabled ? " checked " : "" %>>
												<label for="autokick_members-isEnabled" style="padding-left: 3.75rem;" data-toggle-gfba="moderation-autokick-options"></label>
											</div>
										</div>
										<div class="generic-feature-box-description">
											<p>
												Automatically kick members after a set period of inactivity
												<span class="help">Members that have not sent a message or joined a voice channel for this length of time will be automatically kicked from the server.</span>
											</p>
										</div>
										<div class="generic-feature-box-addon">
											<div class="field">
												<div class="control">
													<span class="select is-primary is-small">
														<select name="autokick_members-max_inactivity" id="moderation-autokick-options"<%- configData.moderation.autokick_members.isEnabled ? '' : ' disabled' %>>
															<option value="43200000"<%= configData.moderation.autokick_members.max_inactivity === 43200000 ? " selected" : "" %>>12 hours</option>
															<option value="86400000"<%= configData.moderation.autokick_members.max_inactivity === 86400000 ? " selected" : "" %>>24 hours</option>
															<option value="172800000"<%= configData.moderation.autokick_members.max_inactivity === 172800000 ? " selected" : "" %>>2 days</option>
															<option value="604800000"<%= configData.moderation.autokick_members.max_inactivity === 604800000 ? " selected" : "" %>>1 week</option>
															<option value="1209600000"<%= configData.moderation.autokick_members.max_inactivity === 1209600000 ? " selected" : "" %>>2 weeks</option>
															<option value="2592000000"<%= configData.moderation.autokick_members.max_inactivity === 2592000000 ? " selected" : "" %>>30 days</option>
														</select>
													</span>
												</div>
											</div>
										</div>
									</div>
								</div>
							</div>
							<div class="moderation-feature">
								<br>
								<h4 class="subtitle is-4">
									New Member Roles <% if (!pageData.hasAutoRoles) { %><span class="tag is-warning is-light">Premium</span><% } %>
								</h4>
								<% if (!pageData.hasAutoRoles) { %>
								<article class="message is-warning">
									<div class="message-body">
										Auto roles require a premium subscription. <a href="/membership">Upgrade now</a> to automatically assign roles to new members.
									</div>
								</article>
								<% } else { %>
								<div class="field">
									<div class="control">
										<% pageData.roleData.forEach(role => { %>
											<label class="checkbox">
											<input name="new_member_roles-<%= role.id %>" type="checkbox"<%= configData.moderation.new_member_roles.includes(role.id) ? " checked" : "" %>>
												<span style="color: #<%= role.color %>;" title="<%= role.name %>"><%= role.name %></span>
											</label>
											<br>
										<% }) %>
										<span class="help">New members will be automatically assigned the selected roles.</span>
									</div>
								</div>
								<% } %>
							</div>
							<div class="moderation-feature">
								<br>
								<h4 class="subtitle is-4">
									Moderation Logging
								</h4>
								<article class="message is-primary">
									<div class="message-body">
										<div class="content">
											Skynet's ModLog feature tracks all server moderation actions, member activity, and structural changes. It stores incidents as cases with reasons, edit history, and severity levels. Use <code>/modlog search</code>, <code>/modlog stats</code>, and <code>/modlog export</code> for advanced queries and reporting.
										</div>
									</div>
								</article>
								<div class="box is-paddingless generic-feature">
									<div class="generic-feature-box">
										<div class="generic-feature-box-slider">
											<div class="field">
												<input id="modlog-isEnabled" type="checkbox" name="modlog-isEnabled" class="switch is-medium is-success is-rounded"<%= configData.modlog.isEnabled ? " checked " : "" %>>
												<label for="modlog-isEnabled" style="padding-left: 3.75rem;" data-toggle-gfba="moderation-modlog-options,modlog-events-section"></label>
											</div>
										</div>
										<div class="generic-feature-box-description">
											<p>Enable Skynet <strong>ModLog</strong></p>
										</div>
										<div class="generic-feature-box-addon is-pulled-right">
											<div class="field">
												<div class="control">
													<div class="select is-primary is-small">
														<select id="moderation-modlog-options" name="modlog-channel_id"<%= !configData.modlog.isEnabled ? " disabled " : "" %>>
															<% pageData.channelData.forEach(channel => { %>
															<option value="<%= channel.id %>"<%= configData.modlog.channel_id === channel.id ? " selected" : "" %>>#<%= channel.name %></option>
															<% }); %>
														</select>
													</div>
												</div>
											</div>
										</div>
									</div>
									<div id="modlog-events-section" class="generic-feature-box-content"<%= !configData.modlog.isEnabled ? " style='display:none;'" : "" %>>
										<div class="content">
											<p class="has-text-weight-semibold">Moderation Events:</p>
											<div class="columns is-multiline">
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-strikes"<%= configData.modlog.events.strikes ? " checked" : "" %>>
														<strong>Strikes</strong> - User warnings
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-kicks"<%= configData.modlog.events.kicks ? " checked" : "" %>>
														<strong>Kicks</strong> - Member kicks
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-bans"<%= configData.modlog.events.bans ? " checked" : "" %>>
														<strong>Bans</strong> - Bans and unbans
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-mutes"<%= configData.modlog.events.mutes ? " checked" : "" %>>
														<strong>Mutes</strong> - Mute actions
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-filter_violations"<%= configData.modlog.events.filter_violations ? " checked" : "" %>>
														<strong>Filter Violations</strong> - Spam triggers
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-raid_alerts"<%= configData.modlog.events.raid_alerts ? " checked" : "" %>>
														<strong>Raid Alerts</strong> - Raid detection
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-alt_detection"<%= configData.modlog.events.alt_detection ? " checked" : "" %>>
														<strong>Alt Detection</strong> - Alt accounts
													</label>
												</div>
											</div>
											<p class="has-text-weight-semibold" style="margin-top: 1rem;">Member & Server Events:</p>
											<div class="columns is-multiline">
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-message_deleted"<%= configData.modlog.events.message_deleted ? " checked" : "" %>>
														<strong>Message Deleted</strong> - Deleted messages
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-message_edited"<%= configData.modlog.events.message_edited ? " checked" : "" %>>
														<strong>Message Edited</strong> - Edited messages
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-member_joined"<%= configData.modlog.events.member_joined ? " checked" : "" %>>
														<strong>Member Joined</strong> - New members
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-member_left"<%= configData.modlog.events.member_left ? " checked" : "" %>>
														<strong>Member Left</strong> - Members leaving
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-bulk_delete"<%= configData.modlog.events.bulk_delete ? " checked" : "" %>>
														<strong>Bulk Delete</strong> - Bulk message deletes
													</label>
												</div>
											</div>
											<p class="has-text-weight-semibold" style="margin-top: 1rem;">Role & Channel Events:</p>
											<div class="columns is-multiline">
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-role_created"<%= configData.modlog.events.role_created ? " checked" : "" %>>
														<strong>Role Created</strong> - New roles
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-role_deleted"<%= configData.modlog.events.role_deleted ? " checked" : "" %>>
														<strong>Role Deleted</strong> - Deleted roles
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-role_modified"<%= configData.modlog.events.role_modified ? " checked" : "" %>>
														<strong>Role Modified</strong> - Role changes
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-channel_created"<%= configData.modlog.events.channel_created ? " checked" : "" %>>
														<strong>Channel Created</strong> - New channels
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-channel_deleted"<%= configData.modlog.events.channel_deleted ? " checked" : "" %>>
														<strong>Channel Deleted</strong> - Deleted channels
													</label>
												</div>
												<div class="column is-half">
													<label class="checkbox">
														<input type="checkbox" name="modlog-events-channel_modified"<%= configData.modlog.events.channel_modified ? " checked" : "" %>>
														<strong>Channel Modified</strong> - Channel changes
													</label>
												</div>
											</div>
										</div>
									</div>
								</div>
							</div>
							</div>
						</div>
						<br>
						<% var formButtonsUnsaved = false; %>
						<%- include('../partials/form-buttons') %>
						<%- include('../partials/form-buttons-bar') %>
					</form>
				</div>
			</div>
		</div>
	</section>

	<%- include('../partials/footer') %>
	<%- include('../partials/scroll-top-button') %>
</body>
</html>
