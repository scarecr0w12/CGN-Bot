<!DOCTYPE html>
<html lang="en">
<head>
	<title>Channel Management - <%= serverData.name %></title>
	<%- include('../partials/head', {bot_page: "admin-server-channels"}) %>
</head>
<body onload="SkynetUtil.SFS();">
	<%- include('../partials/dashboard-header') %>
	<%- include('../partials/dashboard-socket-updates') %>

	<section class="section is-white">
		<div class="container">
			<div class="columns">
				<div id="menu" class="column is-one-quarter">
					<%- include('../partials/admin-menu') %>
				</div>
				<div class="column">
					<h1 class="title">
						<span class="icon"><i class="fas fa-hashtag"></i></span>
						<span>Channel Management</span>
					</h1>
					<article class="message is-primary modern-card">
						<div class="message-body">
							Manage server channels, categories, and permissions.
						</div>
					</article>

					<div class="section">
						<h2 class="title is-4">Categories</h2>
						<div class="channel-list">
					<% if (pageData.categories && pageData.categories.length > 0) { %>
						<% pageData.categories.forEach(category => { %>
							<div class="box" data-channel-id="<%= category.id %>">
								<div class="channel-info">
									<span class="channel-icon"><i class="fas fa-folder"></i></span>
									<span class="channel-name"><%= category.name %></span>
								</div>
							</div>
						<% }) %>
					<% } else { %>
						<p class="text-muted">No categories found</p>
					<% } %>
						</div>
					</div>

					<div class="section">
						<h2 class="title is-4">Text Channels</h2>
						<div class="channel-list">
					<% if (pageData.textChannels && pageData.textChannels.length > 0) { %>
						<% pageData.textChannels.forEach(channel => { %>
							<div class="box" data-channel-id="<%= channel.id %>">
								<div class="channel-info">
									<span class="channel-icon"><i class="fas fa-hashtag"></i></span>
									<span class="channel-name"><%= channel.name %></span>
									<% if (channel.topic) { %>
										<span class="channel-topic"><%= channel.topic %></span>
									<% } %>
								</div>
							</div>
						<% }) %>
					<% } else { %>
						<p class="text-muted">No text channels found</p>
					<% } %>
						</div>
					</div>

					<div class="section">
						<h2 class="title is-4">Voice Channels</h2>
						<div class="channel-list">
					<% if (pageData.voiceChannels && pageData.voiceChannels.length > 0) { %>
						<% pageData.voiceChannels.forEach(channel => { %>
							<div class="box" data-channel-id="<%= channel.id %>">
								<div class="channel-info">
									<span class="channel-icon"><i class="fas fa-volume-up"></i></span>
									<span class="channel-name"><%= channel.name %></span>
								</div>
							</div>
						<% }) %>
					<% } else { %>
						<p class="text-muted">No voice channels found</p>
					<% } %>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<%- include('../partials/footer') %>
	<%- include('../partials/scroll-top-button') %>
</body>
</html>
