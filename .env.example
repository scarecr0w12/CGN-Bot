# Core bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CLIENT_TOKEN=
SHARD_TOTAL=auto

# Bot version info (static per deployment)
# These are read-only - update and restart after version upgrades
BOT_VERSION=1.6.0
BOT_BRANCH=production

# Development mode - set to true to prevent automatic updates from overwriting local files
# Useful for development installs where you don't want updates to overwrite your changes
DEV_MODE=false

# NOTE: The following settings have been MIGRATED to the database (SiteSettings collection):
# - BOT_STATUS, BOT_ACTIVITY_NAME, BOT_ACTIVITY_TYPE, BOT_ACTIVITY_TWITCH_URL
# - Maintainers, Wiki Contributors, Blocklists
# - Permission levels, PM forwarding, Homepage settings
#
# These are now managed via the Maintainer Console in the web dashboard.
# Run `node scripts/migrate-config-to-db.js` to migrate existing config.json data.
# The old Configurations/config.json file is no longer needed.

# Web / session
HOSTING_URL=https://skynetbot.com/
SERVER_IP=0.0.0.0
HTTP_PORT=80
HTTPS_PORT=443
SESSION_SECRET=change-me
ENCRYPTION_PASSWORD=change-me
ENCRYPTION_IV=change-me
LOG_LEVEL=info
LOG_FILE_LEVEL=info

# Database
# MariaDB Configuration
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=skynet
MARIADB_PASSWORD=
MARIADB_DATABASE=skynet
MARIADB_POOL_SIZE=10

# Sentry (optional)
SENTRY_DSN=

# Social Media Alerts API Keys
# Twitch API - Get from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube Data API v3 - Get from https://console.cloud.google.com/
YOUTUBE_API_KEY=

# Uptime Kuma (optional)
# URL should use host.docker.internal if Kuma is in Docker and bot is on host
UPTIME_KUMA_URL=http://localhost:3001
UPTIME_KUMA_API_KEY=
UPTIME_KUMA_STATUS_PAGE_SLUG=status
# Push token for bot heartbeat (create a "Push" type monitor in Uptime Kuma)
UPTIME_KUMA_PUSH_TOKEN=

# Slash Commands (optional)
REGISTER_SLASH_COMMANDS=true
SLASH_COMMANDS_GUILD_ID=

# Third-party tokens (optional)
DISCORD_BOTS_ORG_TOKEN=
DISCORD_LIST_TOKEN=
DISCORD_BOTS_TOKEN=
GIPHY_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_API_KEY=
IMGUR_CLIENT_ID=
MS_TRANSLATE_KEY=
TWITCH_CLIENT_ID=
WOLFRAM_APP_ID=
OPEN_EXCHANGE_RATES_KEY=
OMDB_API_KEY=
GIST_KEY=
OPENWEATHERMAP_KEY=

# ============================================
# TIERED MEMBERSHIP SYSTEM
# ============================================

# Token Encryption (for storing OAuth tokens securely)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# OAuth Providers (for linked accounts)
# Note: Discord OAuth is configured above (DISCORD_CLIENT_ID/SECRET)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
TWITCH_OAUTH_CLIENT_ID=
TWITCH_OAUTH_CLIENT_SECRET=
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_WEBHOOK_SECRET=

# Payment Providers
# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal (https://developer.paypal.com/dashboard/applications)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# BTCPay Server (for cryptocurrency payments)
BTCPAY_SERVER_URL=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Email is used for receipts, notifications, and admin alerts

# Admin email for receiving alerts
ADMIN_EMAIL=

# Custom SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SendGrid (https://sendgrid.com/)
# Set email provider to 'sendgrid' in maintainer console
SENDGRID_API_KEY=

# Mailgun (https://www.mailgun.com/)
# Set email provider to 'mailgun' in maintainer console
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_USER=
MAILGUN_SMTP_PASS=

# Amazon SES (https://aws.amazon.com/ses/)
# Set email provider to 'ses' in maintainer console
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1

# ============================================
# AUDIO SYSTEM CONFIGURATION (Lavalink)
# ============================================
# Lavalink is a standalone audio server that handles music streaming
# It runs as a separate Docker container (see docker-compose.yml)
# No cookies or authentication required - works out of the box!

LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Optional: Override sender info (can also be set in maintainer console)
EMAIL_FROM_NAME=
EMAIL_FROM_ADDRESS=

# ============================================
# CLOUDFLARE INTEGRATION
# ============================================

# Cloudflare API credentials (for cache management, analytics, security)
# Get API Token from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone.Cache Purge, Zone.Zone Settings, Zone.Analytics
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Turnstile (Bot Protection)
# Get your sitekey and secret from https://dash.cloudflare.com/?to=/:account/turnstile
CLOUDFLARE_TURNSTILE_SITEKEY=
CLOUDFLARE_TURNSTILE_SECRET=
CLOUDFLARE_TURNSTILE_THEME=auto
CLOUDFLARE_TURNSTILE_SIZE=normal

# Cloudflare R2 Storage (Object Storage)
# Get credentials from https://dash.cloudflare.com/?to=/:account/r2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=skynet-assets
CLOUDFLARE_R2_PUBLIC_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_DOMAIN=

# Enable Cloudflare proxy trust (set to true when using Cloudflare proxy)
CLOUDFLARE_PROXY_ENABLED=true

# Security settings
# Block direct access to origin (only allow Cloudflare IPs)
CLOUDFLARE_REQUIRE_PROXY=false
# Comma-separated list of blocked country codes (ISO 3166-1 alpha-2)
CLOUDFLARE_BLOCKED_COUNTRIES=

# ============================================
# MONITORING STACK (Prometheus + Grafana Cloud)
# ============================================

# Grafana Cloud - https://scarecr0w12.grafana.net/
# Get credentials from: My Account > API Keys

# Loki (Logs) - Get from: Connections > Data sources > Loki
# URL format: https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USERNAME=
GRAFANA_LOKI_API_KEY=

# Prometheus (Metrics) - Get from: Connections > Data sources > Prometheus
# URL format: https://prometheus-prod-XXX.grafana.net/api/prom/push
GRAFANA_PROMETHEUS_URL=
GRAFANA_PROMETHEUS_USERNAME=
GRAFANA_PROMETHEUS_API_KEY=

# IndexNow (for instant search engine indexing)
# Get your API key from Bing Webmaster Tools: https://www.bing.com/webmasters
# The key file will be served at /{key}.txt for verification
INDEXNOW_API_KEY=

# Matomo Analytics (for website analytics dashboard)
# URL to your Matomo instance (e.g., https://analytics.example.com)
MATOMO_URL=
# Site ID in Matomo (usually 1 for the first site)
MATOMO_SITE_ID=1
# API Token from Matomo (Administration > Personal > Security > Auth tokens)
MATOMO_TOKEN=

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis provides cross-shard caching, session storage, and rate limiting
# Install on server: sudo apt install redis-server
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Optional: Use a specific database number (0-15)
REDIS_DB=0
